      "id": "node-config",
      "name": "Campaign Config",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        -608,
        304
      ]
    },
    {
      "parameters": {
        "url": "=https://api.opencorporates.com/v0.4/companies/search?q=&jurisdiction_code=us&sic_codes={{ $json.sic_code }}&per_page=10&format=json",
        "options": {
          "response": {
            "response": {
              "responseFormat": "json"
            }
          }
        }
      },
      "id": "node-scrape-businesses",
      "name": "Scrape Businesses by SIC Code",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        -400,
        304
      ]
    },
    {
      "parameters": {},
      "id": "node-build-persona",
      "name": "Build Audience Persona",
      "type": "n8n-nodes-base.openAi",
      "typeVersion": 1.8,
      "position": [
        -208,
        304
      ]
    },
    {
      "parameters": {
        "jsCode": "const raw = $input.item.json.message?.content ?? $input.item.json.choices?.[0]?.message?.content ?? '{}';\nlet persona;\ntry {\n  persona = JSON.parse(raw);\n} catch(e) {\n  // Fallback persona for dentists\n  persona = {\n    persona_name: 'The Busy Dentist',\n    pain_points: ['Too much admin work', 'Difficulty attracting new patients', 'Managing staff scheduling'],\n    goals: ['Grow patient base', 'Reduce operational overhead', 'Improve work-life balance'],\n    content_tone: 'professional but approachable',\n    key_topics: ['practice management', 'patient experience', 'dental technology', 'business growth', 'work-life balance']\n  };\n}\nreturn { json: { persona, ...($('Campaign Config').item.json) } };"
      },
      "id": "node-parse-persona",
      "name": "Parse Persona JSON",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        0,
        304
      ]
    },
    {
      "parameters": {
        "url": "=https://www.reddit.com/r/dentistry/hot.json?limit=5",
        "options": {
          "response": {
            "response": {
              "responseFormat": "json"
            }
          }
        }
      },
      "id": "node-fetch-trends",
      "name": "Fetch Trending Topics",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        208,
        304
      ]
    },
    {
      "parameters": {},
      "id": "node-generate-content",
      "name": "Generate Edutainment Content",
      "type": "n8n-nodes-base.openAi",
      "typeVersion": 1.8,
      "position": [
        400,
        304
      ]
    },
    {
      "parameters": {
        "jsCode": "const content = $input.item.json.message?.content ?? $input.item.json.choices?.[0]?.message?.content ?? '';\nreturn {\n  json: {\n    post_text: content.trim(),\n    platform: $('Parse Persona JSON').item.json.target_platform,\n    blotato_api_key: $('Parse Persona JSON').item.json.blotato_api_key,\n    blotato_account_id: $('Parse Persona JSON').item.json.blotato_account_id,\n    generated_at: new Date().toISOString()\n  }\n};"
      },
      "id": "node-extract-post",
      "name": "Extract Post Text",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        608,
        304
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://backend.blotato.com/v2/posts",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {}
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"post\": {\n    \"accountId\": \"{{ $json.blotato_account_id }}\",\n    \"content\": {\n      \"text\": {{ JSON.stringify($json.post_text) }},\n      \"mediaUrls\": [],\n      \"platform\": \"{{ $json.platform }}\"\n    },\n    \"target\": {\n      \"targetType\": \"{{ $json.platform }}\"\n    }\n  },\n  \"useNextFreeSlot\": true\n}",
        "options": {
          "response": {
            "response": {
              "responseFormat": "json"
            }
          }
        }
      },
      "id": "node-post-blotato",
      "name": "Post via Blotato",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        800,
        304
      ]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "log-status",
              "name": "status",
              "value": "success",
              "type": "string"
            },
            {
              "id": "log-submission",
