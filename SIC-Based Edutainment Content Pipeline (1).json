              "value": "={{ $json.postSubmissionId }}",
              "type": "string"
            },
            {
              "id": "log-time",
              "name": "completedAt",
              "value": "={{ $now }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "node-log-result",
      "name": "Log Result",
      "type": "n8n-nodes-base.set",
